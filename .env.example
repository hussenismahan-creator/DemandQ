# DemandQ environment configuration
#
# Which analysis backend to use. Defaults to the built-in mock engine.
# Set to "llm" only after implementing LlmAnalysisProvider in
# src/services/analysis/llm.provider.ts (and a server route for the API key).
NEXT_PUBLIC_ANALYSIS_PROVIDER=mock

# When you enable the LLM provider, keep the key server-side only.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
